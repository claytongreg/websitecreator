generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  name             String?
  image            String?
  emailVerified    DateTime?
  hashedPassword   String?
  stripeCustomerId String?       @unique
  accounts         Account[]
  sessions         Session[]
  sites            Site[]
  usageRecords     UsageRecord[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Site {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  subdomain    String            @unique
  customDomain String?
  pages        Page[]
  inspirations SiteInspiration[]
  themeSettings Json?
  published    Boolean           @default(false)
  publishedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model Page {
  id        String        @id @default(cuid())
  siteId    String
  site      Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  slug      String
  title     String
  html      String
  css       String?
  versions  PageVersion[]
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([siteId, slug])
}

model PageVersion {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  html      String
  css       String?
  createdAt DateTime @default(now())
}

model SiteInspiration {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sourceUrl String?
  colors    Json
  fonts     Json
  layout    String?
  mood      String?
  createdAt DateTime @default(now())
}

model UsageRecord {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  model        String
  inputTokens  Int
  outputTokens Int
  costCents    Float
  action       String
  createdAt    DateTime @default(now())
}
